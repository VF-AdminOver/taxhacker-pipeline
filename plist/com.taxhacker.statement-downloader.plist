<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.taxhacker.statement-downloader</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/opt/taxhacker-pipeline/scripts/capital_one_to_taxhacker.py</string>
        <string>/Users/YOU/Documents/bank_statements/</string>
        <string>/Users/YOU/Documents/taxhacker_import.csv</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/YOU</string>
    
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    
    <key>StandardOutPath</key>
    <string>/tmp/taxhacker_downloader.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/taxhacker_downloader.err</string>
    
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
